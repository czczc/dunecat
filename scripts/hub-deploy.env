# Per-host deploy defaults, sourced by scripts/hub-deploy.sh.
#
# The twister prod hub is served under a URL sub-path
# (https://www.phy.bnl.gov/twister/dunecat/), so the SPA must be built
# with a matching base or its asset URLs 404. This keeps a bare
# `./scripts/hub-deploy.sh` correct without remembering the knob.
#
# An explicit `VITE_BASE=... ./scripts/hub-deploy.sh` still overrides this.
# Keep the trailing slash, and keep it in sync with `--root-path` in the
# dunecat-hub systemd unit.
export VITE_BASE="${VITE_BASE:-/twister/dunecat/}"
