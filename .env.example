METACAT_SERVER_URL=https://metacat.fnal.gov:9443/dune_meta_prod/app
METACAT_AUTH_SERVER_URL=https://metacat.fnal.gov:8143/auth/dune

# DUNE conditions database (read-only HTTP, no auth required).
CONDB_SERVER_URL=https://dbdata0vm.fnal.gov:9443/dune_runcon_prod

# DUNE Rucio (file-replica lookups). Bearer is minted by `dunecat login`
# (which wraps htgettoken --issuer=dune). Bearer is good ~3 h; the vault
# refresh is good 10 d. The web server re-mints both in the background as
# they approach expiry.
RUCIO_HOST=https://dune-rucio.fnal.gov
RUCIO_AUTH_HOST=https://dune-rucio.fnal.gov
RUCIO_ACCOUNT=
BEARER_TOKEN_FILE=/tmp/bt_u502

# Defaults for `dunecat login`.
METACAT_USER=
# Method only applies to the explicit `dunecat login metacat` form.
# `dunecat login` (no args) always uses the OIDC pipeline.
# Options: token (default), password (interactive fallback), x509 (cert + key).
# METACAT_AUTH_METHOD=token

# --- dunecat hub (multi-user remote deployment) ---
# Only set this if you run `uv run dunecat hub`. The local app
# (`uv run dunecat server`) ignores it.
#
# AES-GCM key for encrypting per-user vault tokens in the hub's
# SQLite DB. 32 random bytes, base64-encoded. Generate with:
#   python -c 'import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())'
#
# If left blank, the hub auto-generates a key in ~/.dunecat/hub.key
# on first run (dev convenience; logs a WARNING). For prod, set this
# explicitly so a misplaced key file can't silently break decryption.
# DUNECAT_HUB_SECRET_KEY=

# Optional: override the SQLite DB path (default: ~/.dunecat/hub.sqlite).
# DUNECAT_HUB_DB=/var/lib/dunecat-hub/hub.sqlite
