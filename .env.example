METACAT_SERVER_URL=https://metacat.fnal.gov:9443/dune_meta_prod/app
METACAT_AUTH_SERVER_URL=https://metacat.fnal.gov:8143/auth/dune

# DUNE conditions database (read-only HTTP, no auth required).
CONDB_SERVER_URL=https://dbdata0vm.fnal.gov:9443/dune_runcon_prod

# DUNE Rucio (file-replica lookups). Requires a DUNE-scoped OIDC bearer
# token; mint with htgettoken:
#   htgettoken --vaulttokenttl=10d --vaultserver=htvaultprod.fnal.gov --issuer=dune
# Bearer token is good ~3h; vault refresh is good 10d (one browser dance per
# 10 days, plus a quiet re-mint every couple hours — e.g. via cron/launchd).
RUCIO_HOST=https://dune-rucio.fnal.gov
RUCIO_AUTH_HOST=https://dune-rucio.fnal.gov
RUCIO_ACCOUNT=
BEARER_TOKEN_FILE=/tmp/bt_u502

# Defaults for `dunecat login` — override on the command line with --user / --method.
# Supported methods: password (interactive), x509 (cert + key), token (bearer token).
METACAT_USER=
METACAT_AUTH_METHOD=password
